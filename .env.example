# ─── Database (Neon / Railway / Supabase) ───────────────────────
DATABASE_URL="postgresql://user:password@host:5432/reviewboost?sslmode=require"

# ─── Clerk Auth ──────────────────────────────────────────────────
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY="pk_test_..."
CLERK_SECRET_KEY="sk_test_..."
NEXT_PUBLIC_CLERK_SIGN_IN_URL="/sign-in"
NEXT_PUBLIC_CLERK_SIGN_UP_URL="/sign-up"
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL="/dashboard"
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL="/dashboard"
CLERK_WEBHOOK_SECRET="whsec_..."       # from Clerk dashboard → webhooks

# ─── Anthropic ───────────────────────────────────────────────────
ANTHROPIC_API_KEY="sk-ant-..."         # NEVER expose this client-side

# ─── Stripe ──────────────────────────────────────────────────────
STRIPE_SECRET_KEY="sk_test_..."
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."      # from Stripe dashboard → webhooks
STRIPE_STARTER_PRICE_ID="price_..."   # ₹999/mo product
STRIPE_PRO_PRICE_ID="price_..."       # ₹2499/mo product

# ─── App ─────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="https://reviewboost.ai"
NEXT_PUBLIC_APP_NAME="ReviewBoost"

# ─── Rate limiting (Upstash Redis) ───────────────────────────────
UPSTASH_REDIS_REST_URL="https://..."
UPSTASH_REDIS_REST_TOKEN="..."

# ─── Storage (Cloudflare R2 or AWS S3) ───────────────────────────
R2_ACCOUNT_ID="..."
R2_ACCESS_KEY_ID="..."
R2_SECRET_ACCESS_KEY="..."
R2_BUCKET_NAME="reviewboost-assets"
NEXT_PUBLIC_CDN_URL="https://cdn.reviewboost.ai"
